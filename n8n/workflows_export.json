          "jsCode": "const modeRaw = String($json.execution_mode || 'prod').trim().toLowerCase();\nconst mode = ['prod', 'test', 'dry_run', 'ai_test'].includes(modeRaw) ? modeRaw : 'prod';\nlet bills = Array.isArray($json.bills) ? $json.bills : [];\nconst isDryRun = mode === 'dry_run';\nconst isAiTest = mode === 'ai_test';\nif (mode === 'test' || isDryRun || isAiTest) { bills = bills.slice(0, 5); }\nreturn [{\n  json: {\n    ...$json,\n    execution_mode: mode,\n    is_dry_run: isDryRun,\n    is_ai_test: isAiTest,\n    bills,\n    bill_count: bills.length\n  }\n}];"
