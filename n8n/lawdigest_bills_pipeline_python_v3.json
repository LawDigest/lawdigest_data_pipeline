      "name": "Set Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        440,
        280
      ]
    },
    {
      "parameters": {
        "command": "=/home/ubuntu/project/lawdigest/.venv/bin/python /home/ubuntu/project/lawdigest/scripts/run_n8n_db_pipeline.py --step bills_fetch --mode {{ $json.execution_mode }} --start-date {{ $json.start_date }} --end-date {{ $json.end_date }} --age {{ $json.age }}"
      },
      "id": "fetch-bills-python",
      "name": "Fetch Bills (Python)",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        660,
        280
      ]
    },
    {
      "parameters": {
        "jsCode": "const bills = JSON.parse($json.stdout || '[]');\nreturn [{ json: { ...$node[\"Set Context\"].data.json, bills, bill_count: bills.length, is_dry_run: $node[\"Set Context\"].data.json.execution_mode === 'dry-run' } }];"
      },
      "id": "parse-fetch-result",
      "name": "Parse Fetch Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        280
      ]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.bill_count}}",
              "operation": "larger",
              "value2": 0
            }
          ]
        }
      },
      "id": "if-has-data",
      "name": "Has Data?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1100,
        280
      ]
    },
    {
      "parameters": {
        "jsCode": "const bills = Array.isArray($json.bills) ? $json.bills : [];\nreturn bills.map(bill => ({ json: { ...$json, ...bill, bills: undefined } }));"
      },
      "id": "explode-bills",
      "name": "Explode Bills",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        280
      ]
    },
    {
      "parameters": {
        "batchSize": 1
      },
      "id": "loop-items",
      "name": "Loop Over Bills",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1540,
        280
      ]
    },
    {
      "parameters": {
        "command": "=/home/ubuntu/project/lawdigest/.venv/bin/python /home/ubuntu/project/lawdigest/scripts/run_n8n_db_pipeline.py --step bills_summarize --mode {{ $node[\"Set Context\"].data.json.execution_mode }} --input-json '{{ JSON.stringify($json) }}'"
      },
      "id": "summarize-bill-python",
      "name": "AI Summarize (Python)",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1760,
        280
      ]
    },
    {
      "parameters": {
        "jsCode": "const summarized = JSON.parse($json.stdout || '[]');\nreturn summarized.map(item => ({ json: item }));"
      },
      "id": "parse-summarize-result",
      "name": "Parse Summarize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1980,
        280
      ]
    },
    {
      "parameters": {
        "command": "=/home/ubuntu/project/lawdigest/.venv/bin/python /home/ubuntu/project/lawdigest/scripts/run_n8n_db_pipeline.py --step bills_upsert --mode {{ $node[\"Set Context\"].data.json.execution_mode }} --input-json '{{ JSON.stringify($json) }}'"
      },
      "id": "upsert-bill-python",
      "name": "DB Upsert (Python)",
